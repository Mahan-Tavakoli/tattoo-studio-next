# Backend API base URL
# Development: http://localhost:3100
# Production: your deployed API URL
NEXT_PUBLIC_API_URL=http://localhost:3100

# Public URL of THIS frontend site, used to build the walk-in QR upload link
# that customers scan. Leave empty to auto-detect from the browser origin
# (window.location.origin) — correct for most setups. Set it explicitly only if
# the reception tablet is served from a different host than the phone should
# reach, e.g. https://booking.your-studio.com
NEXT_PUBLIC_SITE_URL=
